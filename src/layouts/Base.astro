---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Engineering portfolio — full-stack platforms, machine-vision software, and AI automation.' } = Astro.props;
const year = new Date().getFullYear();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body>
    <header class="site-header">
      <div class="wrap">
        <a href="/" class="brand">~/portfolio<span class="dot">.</span></a>
        <nav class="nav">
          <a href="/#demo">Demo</a>
          <a href="/#work">Work</a>
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="wrap">
        <span>&copy; {year} — built with Astro</span>
        <span>Designed &amp; coded from scratch</span>
      </div>
    </footer>
  </body>
</html>
