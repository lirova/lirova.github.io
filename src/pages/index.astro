---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import ProjectCard from '../components/ProjectCard.astro';

const projects = (await getCollection('projects'))
  .filter((p) => p.data.featured)
  .sort((a, b) => a.data.order - b.data.order);
---

<Base title="Engineering Portfolio">
  <section class="hero wrap">
    <p class="eyebrow">Software Engineer · Production &amp; Platforms</p>
    <h1>I build systems that run real factories and the tools that build them.</h1>
    <p>
      Full-stack engineer with a manufacturing background. I ship production
      software end to end &mdash; shop-floor execution systems, machine-vision
      test software, and AI automation that turns engineering chores into
      reviewed, merged code. Comfortable from Postgres schemas to C++ camera
      drivers to autonomous agent pipelines.
    </p>
    <div class="links">
      <a href="/#work">↓ See the work</a>
      <a href="https://github.com/lirova" target="_blank" rel="noopener">GitHub ↗</a>
    </div>
  </section>

  <section id="work" class="section wrap">
    <h2 class="section-title">Selected work</h2>
    <div class="grid">
      {projects.map((p) => (
        <ProjectCard
          slug={p.id}
          title={p.data.title}
          summary={p.data.summary}
          domain={p.data.domain}
          stack={p.data.stack}
        />
      ))}
    </div>
  </section>

  <section id="about" class="section wrap">
    <h2 class="section-title">About</h2>
    <div class="prose">
      <p>
        I sit at the seam between manufacturing and software. Day to day I act
        as both a production lead and the solo engineer behind the systems that
        run the floor &mdash; which means I design the tooling, deploy it, and
        then live with the consequences on the next shift.
      </p>
      <p>
        That feedback loop shapes how I build: code-enforced process gates over
        documentation, real-time visibility over after-the-fact reports, and
        automation that removes friction instead of adding dashboards nobody
        reads. Recently I&apos;ve been building autonomous engineering agents
        that take a bug report all the way to a merged, reviewed pull request.
      </p>
    </div>
  </section>
</Base>
