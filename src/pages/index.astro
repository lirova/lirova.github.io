---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import ProjectCard from '../components/ProjectCard.astro';

const projects = (await getCollection('projects'))
  .filter((p) => p.data.featured)
  .sort((a, b) => a.data.order - b.data.order);
---

<Base title="Engineering Portfolio">
  <section class="hero wrap">
    <p class="eyebrow">Systems · Platforms · Automation</p>
    <h1>Systems that run in production.<br />Automation that runs itself.</h1>
    <div class="links">
      <a href="/#demo">↓ Watch it work</a>
      <a href="https://github.com/lirova" target="_blank" rel="noopener">GitHub ↗</a>
    </div>
  </section>

  <section id="demo" class="section wrap">
    <h2 class="section-title">See it work</h2>
    <p style="max-width:60ch;margin:0 0 1.5rem;opacity:.8;">
      A labeled feature request &mdash; built, validated, tested, reviewed,
      and merged by autonomous agents, with no human keystrokes. 45 seconds,
      start to finish:
    </p>
    <video
      controls
      preload="metadata"
      poster="/daki-demo-poster.jpg"
      style="width:100%;border-radius:12px;border:1px solid rgba(255,255,255,.12);display:block;"
    >
      <source src="/daki-demo.mp4?v=2" type="video/mp4" />
      Your browser doesn&apos;t support embedded video &mdash;
      <a href="/daki-demo.mp4?v=2">download the clip</a>.
    </video>
    <p style="max-width:60ch;margin:2.6rem 0 1.4rem;opacity:.8;">
      A second pipeline &mdash; <strong>workbank</strong>: scattered asks from
      Gmail, Calendar, GitHub, and Slack, read by AI into one board of what
      actually needs you. Clear one and it archives at the source:
    </p>
    <video
      controls
      preload="metadata"
      poster="/workbank-demo-poster.jpg"
      style="width:100%;border-radius:12px;border:1px solid rgba(255,255,255,.12);display:block;"
    >
      <source src="/workbank-demo.mp4?v=2" type="video/mp4" />
      <a href="/workbank-demo.mp4?v=2">download the clip</a>.
    </video>
    <p style="margin:1.5rem 0 0;font-size:1.1rem;">
      Want this running in your stack?
      <a href="https://github.com/lirova" target="_blank" rel="noopener">Get in touch &rarr;</a>
    </p>
  </section>

  <section id="work" class="section wrap">
    <h2 class="section-title">Selected work</h2>
    <div class="grid">
      {projects.map((p) => (
        <ProjectCard
          slug={p.id}
          title={p.data.title}
          summary={p.data.summary}
          domain={p.data.domain}
          stack={p.data.stack}
        />
      ))}
    </div>
  </section>

</Base>
